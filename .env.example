# ---- Server ----
PORT=3000
# NODE_ENV est fixé par les scripts npm : dev vs start:prod

# ---- MongoDB ----
# Local :
MONGODB_URI=mongodb://127.0.0.1:27017/lahora

# Atlas :
# Ne jamais mettre ici une vraie URI avec identifiant/mot de passe.
# À renseigner uniquement dans le fichier .env réel.
URI_MONGODB=

# Exemple de format attendu dans .env :
# URI_MONGODB=mongodb+srv://<DB_USER>:<DB_PASSWORD>@<CLUSTER_HOST>/<DATABASE>?retryWrites=true&w=majority&appName=<APP_NAME>

# ---- Email (optionnel) ----
# Active l’envoi d’emails si true et Nodemailer est configuré.
# Par défaut à false dans .env.example pour éviter un envoi accidentel.
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM="La Hora <no-reply@lahora.fr>"
MAIL_TO=contact@lahora.fr

# ---- Contact (optionnel) ----
# Sauver les messages dans server/data/messages.json
CONTACT_SAVE_JSON=false
