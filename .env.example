# ---- Server ----
PORT=3000
# NODE_ENV est fixé par les scripts (dev vs start:prod)

# ---- MongoDB ----
# Local : mongodb://127.0.0.1:27017/lahora
# Atlas : mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/lahora

# ---- Email (optionnel) ----
# Active l’envoi d’emails si true et Nodemailer configuré
MAIL_ENABLED=false
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=your_user
MAIL_PASS=your_password
MAIL_FROM="La Hora <no-reply@lahora.fr>"
MAIL_TO=contact@lahora.fr

# ---- Contact (optionnel) ----
# Sauver les messages dans server/data/messages.json
CONTACT_SAVE_JSON=false
