{
  "name": "la-hora",
  "version": "1.0.0",
  "description": "Site web du bar La Hora (Cocktails & Tapas – La Rochelle)",
  "main": "app.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"nodemon app.js\" \"tailwindcss -i ./public/assets/css/style.css -o ./public/assets/css/output.css --watch\"",
    "build": "npm run build:css",
    "build:css": "tailwindcss -i ./public/assets/css/style.css -o ./public/assets/css/output.css",
    "build:css:prod": "tailwindcss -i ./public/assets/css/style.css -o ./public/assets/css/output.css --minify",
    "start": "node app.js",
    "start:prod": "npm run build:css:prod && cross-env NODE_ENV=production node app.js",
    "migrate:menu": "node scripts/migrate-menuitems.js",
    "reindex:menu": "node scripts/reindex-menuitems.js",
    "dedupe:menu": "node scripts/dedupe-menuitems.js",
    "sync-indexes": "node scripts/sync-indexes.js",
    "export:menu": "node scripts/export-menu.js",
    "seed:menu": "node scripts/seed-menuitems.js"
  },
  "keywords": [
    "bar",
    "cocktails",
    "la-rochelle",
    "express",
    "tailwindcss",
    "ejs"
  ],
  "author": "Will",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^1.41.3",
    "compression": "^1.8.1",
    "connect-flash": "^0.1.1",
    "connect-mongo": "^5.1.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.2",
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^8.1.0",
    "express-session": "^1.18.2",
    "helmet": "^8.1.0",
    "method-override": "^3.0.0",
    "mongoose": "^8.18.1",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^7.0.6",
    "serverless-http": "^4.0.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "cross-env": "^10.0.0",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.3"
  },
  "nodemonConfig": {
    "watch": [
      "app.js",
      "server"
    ],
    "ext": "js,json",
    "ignore": [
      "public/assets/css/output.css",
      "node_modules"
    ]
  }
}
