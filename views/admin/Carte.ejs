<!-- views/admin/carte.ejs -->
<% /* Helpers locaux */ %>
<% function euro(v){ return (Number(v||0)).toFixed(2).replace('.', ','); } %>
<% const moments = ['matin', 'soir']; %>

<%- title = "Gestion de la carte" %>

<section class="max-w-6xl mx-auto py-8">
  <div class="flex items-center justify-between gap-3 mb-6">
    <h1 class="text-2xl font-bold">Gestion de la carte</h1>
    <div class="text-sm text-slate-400">
      Connecté en tant que <%= adminEmail || 'admin' %>
    </div>
  </div>

  <!-- Flash messages -->
  <% if (flash && flash.success && flash.success.length) { %>
    <div class="mb-4 px-4 py-2 rounded bg-emerald-900/30 border border-emerald-600 text-emerald-200">
      <%= flash.success[0] %>
    </div>
  <% } %>
  <% if (flash && flash.error && flash.error.length) { %>
    <div class="mb-4 px-4 py-2 rounded bg-rose-900/30 border border-rose-600 text-rose-200">
      <%= flash.error[0] %>
    </div>
  <% } %>

  <!-- ===== FORM CRUD ===== -->
  <section class="mb-10 rounded-2xl border border-slate-700/50 bg-slate-900/40 p-5">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-xl font-semibold">Ajouter / Modifier un produit</h2>
      <button class="btn-secondary px-3 py-1 text-sm" type="button" id="reset-form">Nouveau</button>
    </div>

    <form id="carte-form" method="POST" action="/admin/carte" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <input type="hidden" name="_id" value="">
      <input type="hidden" name="_method" value="POST"><!-- basculé en PUT en mode édition -->

      <div>
        <label class="block text-sm mb-1">Moment</label>
        <select name="moment" class="w-full bg-slate-800 text-slate-100 rounded px-3 py-2">
          <option value="matin">Matin</option>
          <option value="soir">Soir</option>
        </select>
      </div>

      <div>
        <label class="block text-sm mb-1">Catégorie</label>
        <input name="category" class="w-full bg-slate-800 text-slate-100 rounded px-3 py-2" placeholder="ex: tapas">
      </div>

      <div>
        <label class="block text-sm mb-1">Nom</label>
        <input name="name" required class="w-full bg-slate-800 text-slate-100 rounded px-3 py-2">
      </div>

      <div>
        <label class="block text-sm mb-1">Prix (€)</label>
        <input name="price" type="number" step="0.01" min="0" class="w-full bg-slate-800 text-slate-100 rounded px-3 py-2">
      </div>

      <div class="sm:col-span-2 lg:col-span-3">
        <label class="block text-sm mb-1">Description</label>
        <textarea name="description" rows="2" class="w-full bg-slate-800 text-slate-100 rounded px-3 py-2"></textarea>
      </div>

      <div class="sm:col-span-2 lg:col-span-3">
        <label class="block text-sm mb-1">Image (URL)</label>
        <input name="image" class="w-full bg-slate-800 text-slate-100 rounded px-3 py-2" placeholder="https://...">
      </div>

      <div class="flex items-center gap-2">
        <input id="available" type="checkbox" name="available" class="scale-110">
        <label for="available" class="text-sm">Disponible</label>
      </div>

      <div>
        <label class="block text-sm mb-1">Ordre</label>
        <input name="order" type="number" step="1" min="0" class="w-full bg-slate-800 text-slate-100 rounded px-3 py-2">
      </div>

      <div class="sm:col-span-2 lg:col-span-3 mt-1">
        <button class="btn-primary px-4 py-2" type="submit">Enregistrer</button>
      </div>
    </form>
  </section>

  <!-- ===== LISTE PAR MOMENT & CAT ===== -->
  <% moments.forEach(function(moment){ 
       const cats = Object.keys(carte?.[moment] || {}); %>

    <h2 class="mt-8 mb-2 text-2xl font-semibold"><%= moment === 'matin' ? 'Matin' : 'Soir' %></h2>

    <% if (!cats.length) { %>
      <p class="text-slate-400">Aucune catégorie.</p>
    <% } %>

    <% cats.forEach(function(cat){
         const items = carte[moment][cat] || []; %>

      <h3 class="mt-6 mb-3 text-xl font-medium">
        <span class="uppercase tracking-wide"><%= cat %></span>
        <span class="text-slate-500 text-sm">(<%= items.length %>)</span>
      </h3>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <% items.forEach(function(it){ %>
          <article class="rounded-2xl border border-slate-700/50 bg-slate-900/40 overflow-hidden">
            <div class="aspect-[4/3] overflow-hidden bg-slate-800">
              <img
                src="<%= it.image || '/assets/img/placeholder.jpg' %>"
                alt="<%= it.name %>"
                class="w-full h-full object-cover"
                onerror="this.src='/assets/img/placeholder.jpg'"
              />
            </div>

            <div class="p-4 space-y-2">
              <div class="flex items-center justify-between gap-3">
                <h4 class="font-semibold text-lg truncate"><%= it.name %></h4>
                <span class="text-xs text-slate-400">#<%= it.order ?? 0 %></span>
              </div>

              <% if (it.description) { %>
                <p class="text-slate-300 text-sm leading-relaxed line-clamp-3"><%= it.description %></p>
              <% } %>

              <div class="flex items-center justify-between pt-1">
                <span class="font-medium"><%= euro(it.price) %> €</span>
                <span class="text-xs <%= it.available ? 'text-emerald-400' : 'text-rose-400' %>">
                  <%= it.available ? 'disponible' : 'indisponible' %>
                </span>
              </div>

              <div class="flex items-center gap-2 pt-3">
                <!-- Éditer : remplit le formulaire en haut + passe en mode PUT -->
                <button
                  type="button"
                  class="btn-secondary px-3 py-1 text-sm"
                  data-edit
                  data-item='<%- JSON.stringify({
                    _id: it._id,
                    moment: it.moment,
                    category: (it.categorie || it.category),
                    name: it.name,
                    description: it.description,
                    price: it.price,
                    image: it.image,
                    available: it.available,
                    order: it.order
                  }) %>'>
                  Éditer
                </button>

                <!-- Supprimer -->
                <form method="POST" action="/admin/carte/<%= it._id %>?_method=DELETE" onsubmit="return confirm('Supprimer « <%= it.name %> » ?');">
                  <button class="btn-danger px-3 py-1 text-sm" type="submit">Supprimer</button>
                </form>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
    <% }) %>
  <% }) %>
</section>

<script>
  // Bascule l'action/méthode du formulaire selon mode création/édition
  function setFormMode({ isEdit, id } = { isEdit:false }) {
    const form = document.querySelector('#carte-form');
    if (!form) return;
    const method = form.querySelector('[name="_method"]');
    const idInput = form.querySelector('[name="_id"]');
    if (isEdit) {
      form.action = `/admin/carte/${id}`;
      method.value = 'PUT';
    } else {
      form.action = '/admin/carte';
      method.value = 'POST';
      if (idInput) idInput.value = '';
    }
  }

  // Remplir le formulaire à partir du bouton Éditer
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('[data-edit]');
    if (btn) {
      const data = JSON.parse(btn.getAttribute('data-item') || '{}');
      const form = document.querySelector('#carte-form');
      if (!form) return;

      form.querySelector('[name="_id"]').value = data._id || '';
      form.querySelector('[name="moment"]').value = data.moment || 'matin';
      form.querySelector('[name="category"]').value = (data.categorie || data.category || '');
      form.querySelector('[name="name"]').value = data.name || '';
      form.querySelector('[name="description"]').value = data.description || '';
      form.querySelector('[name="price"]').value = (data.price ?? 0);
      form.querySelector('[name="image"]').value = data.image || '';
      form.querySelector('[name="order"]').value = (data.order ?? 0);
      const avail = form.querySelector('[name="available"]');
      if (avail) avail.checked = !!data.available;

      setFormMode({ isEdit: true, id: data._id });
      form.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // Reset → mode création
    if (e.target?.id === 'reset-form') {
      const form = document.querySelector('#carte-form');
      if (!form) return;
      form.reset();
      setFormMode({ isEdit:false });
    }
  });

  // Par défaut → mode création
  setFormMode({ isEdit:false });
</script>
