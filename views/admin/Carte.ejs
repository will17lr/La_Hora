<!-- views/admin/Carte.ejs -->
<%- title = "Gestion de la carte — La Hora" %>

<section class="container py-8">

  <!-- HEADER -->
  <div class="flex items-center justify-between mb-10">
    <div>
      <h1 class="text-3xl md:text-4xl font-extrabold bg-gradient-to-r from-yellow-400 via-amber-300 to-orange-400 bg-clip-text text-transparent">
        Gestion de la carte
      </h1>
      <p class="mt-1 text-sm text-gray-400">
        Ajouter, modifier ou supprimer les produits du bar.
      </p>
    </div>

    <a href="/admin"
       class="text-sm text-gray-400 hover:text-gray-200 transition">
      ← Retour au dashboard
    </a>
  </div>

  <!-- BOUTON AJOUTER UN PRODUIT -->
  <div class="flex justify-end mb-6">
    <a href="/admin/carte/add"
       class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-yellow-400 text-black font-semibold hover:bg-yellow-300 transition">
      ➕ Ajouter un produit
    </a>
  </div>

  <!-- LISTE DES CATEGORIES -->
  <div class="space-y-10">

    <% if (carte && Object.keys(carte).length > 0) { %>

      <% Object.keys(carte).forEach(categorie => { %>

        <section>

          <!-- CATEGORY HEADER -->
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-2xl font-semibold text-white flex items-center gap-3">
              <span class="text-yellow-400">•</span>
              <%= categorie.charAt(0).toUpperCase() + categorie.slice(1) %>
            </h2>

            <a href="/admin/carte/add"
               class="text-sm px-3 py-1 bg-gray-800 border border-gray-700 rounded hover:bg-gray-700 transition">
              + Ajouter dans cette catégorie
            </a>
          </div>

          <!-- CATEGORY TABLE -->
          <div class="overflow-hidden rounded-2xl border border-gray-800 bg-gray-950/60 shadow-xl">
            <div class="overflow-x-auto">
              <table class="min-w-full text-sm table-fixed">
                <thead class="text-gray-400 bg-gray-900/80">
                  <tr>
                    <th class="w-1/5 text-left py-3 px-4">Nom</th>
                    <th class="w-2/5 text-left py-3 px-4">Description</th>
                    <th class="w-1/12 text-left py-3 px-4">Prix</th>
                    <th class="w-1/12 text-left py-3 px-4">Image</th>
                    <th class="w-1/5 text-right py-3 px-4">Actions</th>
                  </tr>
                </thead>

                <tbody>
                  <% carte[categorie].forEach(item => { %>
                    <tr class="border-t border-gray-800 hover:bg-gray-800/40 transition">

                      <!-- NOM -->
                      <td class="py-3 px-4 align-top font-semibold text-white break-words">
                        <%= item.name %>
                      </td>

                      <!-- DESCRIPTION -->
                      <td class="py-3 px-4 align-top text-gray-300  break-words whitespace-pre-line">
                        <%= item.description %>
                      </td>

                      <!-- PRIX -->
                      <td class="py-3 px-4 align-top font-semibold text-yellow-300 whitespace-nowrap">
                        <%= item.price %> €
                      </td>

                      <!-- IMAGE -->
                      <td class="py-3 px-4 align-top">
                        <% if (item.image) { %>
                          <img src="<%= item.image %>" alt=""
                               class="h-14 w-14 object-cover rounded-lg border border-gray-700 shadow" />
                        <% } else { %>
                          <span class="text-gray-500 italic">Aucune</span>
                        <% } %>
                      </td>

                      <!-- ACTIONS -->
                      <td class="py-3 px-4 align-top text-right space-y-2">

                      <!-- Bouton MODIFIER -->
                      <a href="/admin/carte/edit/<%= item._id %>"
                        class="w-[87px] inline-flex items-center justify-center gap-1
                                px-2 py-1 text-xs font-medium rounded-full
                                bg-blue-600 hover:bg-blue-500 text-white border border-blue-400 transition">
                          <span>✏️</span>
                          <span>Modifier</span>
                      </a>

                      <!-- Bouton SUPPRIMER -->
                      <form action="/admin/carte/delete/<%= item._id %>" method="post"
                            onsubmit="return confirm('Supprimer ce produit ?');">
                        <button
                          class="w-[87px] inline-flex items-center justify-center gap-1
                                px-2 py-1 text-xs font-medium rounded-full
                                bg-red-600 hover:bg-red-500 text-white border border-red-700 transition">
                          <span>🗑️</span>
                          <span>Supprimer</span>
                        </button>
                      </form>

                    </td>

                    </tr>
                  <% }) %>
                </tbody>

              </table>
            </div>
          </div>

        </section>

      <% }) %>

    <% } else { %>

      <p class="text-gray-400">Aucun produit pour le moment.</p>

    <% } %>

  </div>

</section>
