<!--views/admi/carte-detail.ejs-->
<%- title %>

<section class="container py-10 max-w-2xl">

  <h1 class="text-3xl font-bold text-white mb-6">
    <%= product ? "Modifier un produit" : "Ajouter un produit" %>
  </h1>

  <form action="/admin/carte/save" method="post" class="space-y-6">

    <% if (product) { %>
      <input type="hidden" name="id" value="<%= product._id %>">
    <% } %>

    <!-- NOM -->
    <div>
      <label class="text-gray-300 text-sm">Nom</label>
      <input type="text" name="name" required 
        class="w-full bg-gray-900 text-white border border-gray-700 p-2 rounded"
        value="<%= product?.name || '' %>">
    </div>

    <!-- DESCRIPTION -->
    <div>
      <label class="text-gray-300 text-sm">Description</label>
      <textarea name="description"
        class="w-full bg-gray-900 text-white border border-gray-700 p-2 rounded min-h-[100px]"><%= product?.description || '' %></textarea>
    </div>

    <!-- PRIX -->
    <div>
      <label class="text-gray-300 text-sm">Prix (€)</label>
      <input type="number" step="0.10" name="price" min="0"
        class="w-full bg-gray-900 text-white border border-gray-700 p-2 rounded"
        value="<%= product?.price || '' %>">
        required
    </div>

    <!-- IMAGE -->
    <div>
      <label class="text-gray-300 text-sm">Image (URL)</label>
      <input 
        type="text" 
        id="imageInput"
        name="image"
        class="w-full bg-gray-900 text-white border border-gray-700 p-2 rounded"
        value="<%= product?.image || '' %>"
        placeholder="https://exemple.com/mon-image.jpg"
      >
    </div>

    <!-- APERCU VISUEL -->
    <div id="imagePreviewContainer" class="mt-3">
      <% if (product?.image) { %>
        <img 
          id="imagePreview"
          src="<%= product.image %>" 
          alt="Aperçu image"
          class="h-28 w-28 object-cover rounded-lg border border-gray-700 shadow"
        >
      <% } else { %>
        <img 
          id="imagePreview"
          src="" 
          alt=""
          class="hidden h-28 w-28 object-cover rounded-lg border border-gray-700 shadow"
        >
      <% } %>
    </div>

    <!-- ORDRE -->
    <div>
      <label class="text-gray-300 text-sm">Ordre d’affichage</label>
      <input type="number" name="order" 
        class="w-full bg-gray-900 text-white border border-gray-700 p-2 rounded"
        value="<%= product?.order || 0 %>">
    </div>

    <!-- CATEGORIE -->
    <div>
      <label class="text-gray-300 text-sm">Catégorie</label>
      <select name="category" class="w-full bg-gray-900 text-white border border-gray-700 p-2 rounded">
        <% categories.forEach(cat => { %>
          <option value="<%= cat %>" <%= product?.category === cat ? "selected" : "" %>><%= cat %></option>
        <% }) %>
      </select>
    </div>

    <!-- MOMENT -->
    <div>
      <label class="text-gray-300 text-sm">Moment</label>
      <select name="moment" class="w-full bg-gray-900 text-white border border-gray-700 p-2 rounded">
        <% moments.forEach(m => { %>
          <option value="<%= m %>" <%= product?.moment === m ? "selected" : "" %>><%= m %></option>
        <% }) %>
      </select>
    </div>

    <!-- BOUTONS -->
    <div class="flex justify-between mt-6">
      <a href="/admin/carte" class="text-gray-400 hover:text-gray-200">← Retour</a>

      <button class="px-6 py-2 bg-yellow-400 hover:bg-yellow-300 text-black font-semibold rounded">
        Enregistrer
      </button>
    </div>

  </form>
</section>

<script>
  const input = document.getElementById('imageInput');
  const preview = document.getElementById('imagePreview');

  input.addEventListener('input', () => {
    const url = input.value.trim();

    if (url) {
      preview.src = url;
      preview.classList.remove('hidden');
    } else {
      preview.src = '';
      preview.classList.add('hidden');
    }
  });
</script>
