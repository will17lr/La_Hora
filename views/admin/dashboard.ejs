<%- title = "Dashboard — La Hora" %>

<%
  const todayStr = new Date().toISOString().slice(0, 10);
  const todaysReservations = (reservations || []).filter(r => r.date === todayStr).length;
  const todaysMessages = (contacts || []).filter(c => (c.createdAt ? new Date(c.createdAt).toISOString().slice(0,10) : "") === todayStr).length;
%>

<section class="container py-8">

  <!-- HEADER -->
  <div class="flex items-center justify-between mb-10">
    <div>
      <h1 class="text-3xl md:text-4xl font-extrabold bg-gradient-to-r from-[#cbaf7a] via-[#d8c39a] to-[#cbaf7a] bg-clip-text text-transparent">
        Dashboard
      </h1>
      <p class="mt-1 text-sm text-gray-400">Vue d’ensemble de l’activité de La Hora</p>
    </div>

    <% if (adminEmail) { %>
      <div class="flex flex-col items-end gap-1">
        <span class="px-3 py-1 rounded-full bg-gray-900 border border-gray-700 text-xs uppercase tracking-wide text-gray-300">
          Administrateur
        </span>
        <span class="text-xs text-gray-500"><%= adminEmail %></span>
      </div>
    <% } %>
  </div>


  <!-- KPIs premium -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">

    <!-- Réservations -->
<div class="relative overflow-hidden bg-gray-900/90 border border-gray-800 rounded-2xl p-5 flex items-center gap-4 transition hover:-translate-y-0.5 hover:shadow-xl cursor-pointer">
  <a href="/admin/reservations" class="block w-full h-full flex gap-4">
    
    <div class="relative flex items-center justify-center w-12 h-12 rounded-full bg-[#cbaf7a]/20 border border-[#cbaf7a]/40">
      <span class="text-xl">📅</span>
    </div>

    <div>
      <p class="text-xs uppercase tracking-wide text-gray-400">Réservations</p>

      <!-- même logique que messages -->
      <p class="text-4xl font-bold text-white"><%= kpis.reservations %></p>

      <p class="mt-1 text-xs text-gray-500">
        <span class="font-semibold text-[#cbaf7a]"><%= todaysReservations %></span> aujourd’hui
      </p>
    </div>

  </a>
</div>


    <!-- Messages -->
    <div class="relative overflow-hidden bg-gray-900/90 border border-gray-800 rounded-2xl p-5 flex items-center gap-4 transition hover:-translate-y-0.5 hover:shadow-xl cursor-pointer">
      <a href="/admin/messages" class="block w-full h-full flex gap-4">

        <div class="relative flex items-center justify-center w-12 h-12 rounded-full bg-[#cbaf7a]/20 border border-[#cbaf7a]/40">
          <span class="text-xl">✉️</span>
        </div>

        <div>
          <p class="text-xs uppercase tracking-wide text-gray-400">Messages</p>
          <p class="text-4xl font-bold text-white"><%= kpis.messages %></p>
          <p class="mt-1 text-xs text-gray-500">
            <span class="font-semibold text-[#cbaf7a]"><%= todaysMessages %></span> aujourd’hui
          </p>
        </div>
      </a>
    </div>

    <!-- Carte -->
    <div class="flex-1 bg-gray-900/90 border border-gray-800 rounded-2xl p-6 shadow-lg hover:shadow-xl transition cursor-pointer">
      <a href="/admin/carte" class="block h-full w-full">
        <div class="flex items-center gap-4">
          <div class="h-12 w-12 flex items-center justify-center rounded-xl bg-[#cbaf7a]/10 border border-[#cbaf7a]/40">
            📖
          </div>

          <div>
            <h3 class="text-xl font-semibold text-[#cbaf7a]">
              Gestion de la carte
            </h3>
            <p class="text-sm text-gray-400">
              Modifier les produits, prix, catégories, matin/soir.
            </p>
          </div>
        </div>
      </a>
    </div>

  </div>


  <!-- TABLEAUX -->
  <div class="grid grid-cols-1 xl:grid-cols-2 gap-10">

    <!-- Réservations -->
    <div>
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-xl font-semibold text-white flex items-center gap-2">
          Dernières réservations
          <span class="text-xs px-2 py-0.5 rounded-full bg-gray-800 text-gray-300 border border-gray-700">
            <%= (reservations || []).length %> total
          </span>
        </h2>
        <a href="/admin/reservations" class="text-xs text-[#cbaf7a] hover:text-white transition">
          Voir toutes →
        </a>
      </div>

      <div class="overflow-hidden rounded-xl border border-gray-800 bg-gray-950/60">
        <table class="min-w-full text-sm">
          <thead class="text-gray-400 bg-gray-900/80">
            <tr>
              <th class="py-2 px-3">Date</th>
              <th class="py-2 px-3">Nom</th>
              <th class="py-2 px-3">Personnes</th>
              <th class="py-2 px-3">Heure</th>
              <th class="py-2 px-3">Téléphone</th>
            </tr>
          </thead>

          <tbody>
            <% (reservations || []).slice(-10).reverse().forEach(r => { 
              const isToday = r.date === todayStr;
            %>
              <tr class="border-t border-gray-800 hover:bg-gray-800/40 transition">
                <td class="py-2 px-3">
                  <%= r.date %>
                  <% if (isToday) { %>
                    <span class="ml-2 text-[10px] px-1.5 py-0.5 rounded-full bg-[#cbaf7a]/20 text-[#cbaf7a] border border-[#cbaf7a]/40">
                      Aujourd’hui
                    </span>
                  <% } %>
                </td>

                <td class="py-2 px-3"><%= r.lastname %> <%= r.firstname %></td>
                <td class="py-2 px-3"><%= r.people %></td>
                <td class="py-2 px-3"><%= r.time %></td>
                <td class="py-2 px-3"><%= r.phone %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>


    <!-- Messages -->
    <div>
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-xl font-semibold text-white flex items-center gap-2">
          Derniers messages
          <span class="text-xs px-2 py-0.5 rounded-full bg-gray-800 text-gray-300 border border-gray-700">
            <%= (contacts || []).length %> total
          </span>
        </h2>

        <a href="/admin/messages" class="text-xs text-[#cbaf7a] hover:text-white transition">
          Voir tous →
        </a>
      </div>

      <div class="overflow-hidden rounded-xl border border-gray-800 bg-gray-950/60">
        <table class="min-w-full text-sm">
          <thead class="text-gray-400 bg-gray-900/80">
            <tr>
              <th class="py-2 px-3">Date</th>
              <th class="py-2 px-3">Nom</th>
              <th class="py-2 px-3">Email</th>
              <th class="py-2 px-3">Sujet</th>
              <th class="py-2 px-3">Voir</th>
            </tr>
          </thead>

          <tbody>
            <% (contacts || []).slice(-10).reverse().forEach(c => { 
              const dateStr = c.createdAt ? new Date(c.createdAt).toISOString().slice(0,10) : '';
              const isTodayMsg = dateStr === todayStr;
            %>
              <tr class="border-t border-gray-800 hover:bg-gray-800/40 transition">

                <td class="py-2 px-3">
                  <%= dateStr %>
                  <% if (isTodayMsg) { %>
                    <span class="ml-2 text-[10px] px-1.5 py-0.5 rounded-full bg-[#cbaf7a]/20 text-[#cbaf7a] border border-[#cbaf7a]/40">
                      Nouveau
                    </span>
                  <% } %>
                </td>

                <td class="py-2 px-3"><%= c.name %></td>
                <td class="py-2 px-3"><%= c.email %></td>

                <td class="py-2 px-3 truncate max-w-[180px]" title="<%= c.subject %>">
                  <%= c.subject %>
                </td>

                <td class="py-2 px-3">
                  <a href="/admin/messages/<%= c._id %>" class="inline-flex items-center gap-1 text-xs px-2 py-1 rounded-full bg-gray-800 hover:bg-gray-700 text-[#cbaf7a] border border-gray-700 transition">
                    Voir ↗
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>

        </table>
      </div>
    </div>

  </div>

</section>
