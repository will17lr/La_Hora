<!-- views/admin/login.ejs -->
<%- title = "Connexion admin — La Hora" %>

<section class="max-w-md mx-auto py-10">
  <h1 class="text-2xl font-semibold mb-6">Connexion Admin</h1>

  <% if (error) { %>
    <div class="mb-4 px-3 py-2 rounded bg-red-900/40 border border-red-700 text-red-200">
      <%= error %>
    </div>
  <% } %>

  <form method="post" action="/admin/login" class="space-y-4">
    <input type="hidden" name="next" value="<%= next || '' %>">

    <div>
      <label class="block text-sm mb-1" for="email">Email</label>
      <input
        id="email"
        class="w-full bg-gray-800 text-gray-100 rounded px-3 py-2"
        type="email"
        name="email"
        value="<%= emailTyped || '' %>"
        required
        autocomplete="username"
        autofocus
      >
    </div>

    <div>
      <label class="block text-sm mb-1" for="password">Mot de passe</label>
      <input
        id="password"
        class="w-full bg-gray-800 text-gray-100 rounded px-3 py-2"
        type="password"
        name="password"
        required
        autocomplete="current-password"
      >
    </div>

    <button class="w-full px-4 py-2 rounded bg-or-500 text-white font-semibold hover:bg-or-400 transition">
      Se connecter
    </button>
  </form>
</section>
