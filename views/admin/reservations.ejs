<!--views/admin/reservation.ejs -->
<%- title = "Admin - Réservations – La Hora" %>

<section class="px-2 md:px-0">
  <h1 class="text-3xl font-bold text-yellow-400 mb-6">Réservations reçues</h1>

  <% if (!reservations || !reservations.length) { %>
    <p class="text-gray-400 italic">Aucune réservation pour le moment.</p>
  <% } else { %>
    <div class="overflow-x-auto">
      <table class="min-w-full text-sm">
        
        <thead class="text-gray-400">
          <tr>
            <th class="text-left py-2 pr-4">Date</th>
            <th class="text-left py-2 pr-4">Heure</th>
            <th class="text-left py-2 pr-4">Nom</th>
            <th class="text-left py-2 pr-4">Prénom</th>
            <th class="text-left py-2 pr-4">Personnes</th>
            <th class="text-left py-2 pr-4">Téléphone</th>
            <th class="text-left py-2 pr-4">Email</th>
            <th class="text-left py-2 pr-4">Statut</th>
            <th class="text-left py-2 pr-4">Actions</th>
          </tr>
        </thead>

        <tbody>
          <% reservations.forEach(r => { %>
            <tr class="border-t border-gray-800">
              
              <td class="py-2 pr-4"><%= r.date %></td>
              <td class="py-2 pr-4"><%= r.time %></td>
              <td class="py-2 pr-4"><%= r.lastname %></td>
              <td class="py-2 pr-4"><%= r.firstname %></td>
              <td class="py-2 pr-4"><%= r.people %></td>
              <td class="py-2 pr-4"><%= r.phone %></td>
              <td class="py-2 pr-4"><%= r.email %></td>

              <!-- STATUT -->
              <td class="py-2 pr-4">
                <% if (r.status === "pending") { %>
                  <span class="px-2 py-1 text-yellow-400 rounded bg-yellow-400/20">En attente</span>
                <% } else if (r.status === "confirmed") { %>
                  <span class="px-2 py-1 text-green-400 rounded bg-green-400/20">Confirmée</span>
                <% } else { %>
                  <span class="px-2 py-1 text-red-400 rounded bg-red-400/20">Annulée</span>
                <% } %>
              </td>

              <!-- ACTIONS -->
              <td class="py-2 pr-4 flex gap-2">

                <!-- Bouton VOIR -->
                <a href="/admin/reservations/<%= r._id %>" 
                   class="px-3 py-1 rounded bg-blue-600 hover:bg-blue-500 text-white">
                  Voir
                </a>

                <!-- Bouton SUPPRIMER -->
                <form method="post" 
                      action="/admin/reservations/<%= r._id %>/delete"
                      onsubmit="return confirm('Supprimer cette réservation ?')">
                  <button class="px-3 py-1 rounded bg-red-600 hover:bg-red-500 text-white">
                    Supprimer
                  </button>
                </form>

              </td>

            </tr>
          <% }) %>
        </tbody>

      </table>
    </div>
  <% } %>
</section>
