<!-- views/admin/reservation.ejs -->
<%- title = "Admin - Réservations – La Hora" %>

<section class="px-2 md:px-0">
  <h1 class="text-3xl font-bold text-yellow-400 mb-6">Réservations reçues</h1>

  <% if (!reservations || !reservations.length) { %>
    <p class="text-gray-400 italic">Aucune réservation pour le moment.</p>
  <% } else { %>
    <div class="overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead class="text-gray-400">
          <tr>
            <th class="text-left py-2 pr-4">Date</th>
            <th class="text-left py-2 pr-4">Heure</th>
            <th class="text-left py-2 pr-4">Nom</th>
            <th class="text-left py-2 pr-4">Personnes</th>
            <th class="text-left py-2 pr-4">Téléphone</th>
            <th class="text-left py-2 pr-4">Email</th>
            <th class="text-left py-2 pr-4">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% reservations.forEach(r => { %>
            <tr class="border-t border-gray-800">
              <td class="py-2 pr-4"><%= r.date %></td>
              <td class="py-2 pr-4"><%= r.heure %></td>
              <td class="py-2 pr-4"><%= r.nom %> <%= r.prenom %></td>
              <td class="py-2 pr-4"><%= r.personnes %></td>
              <td class="py-2 pr-4"><%= r.telephone %></td>
              <td class="py-2 pr-4"><%= r.email %></td>
              <td class="py-2 pr-4">
                <form method="post" action="/admin/reservations/<%= r._id %>/delete"
                      onsubmit="return confirm('Supprimer cette réservation ?')">
                  <button class="px-3 py-1 rounded bg-red-600 hover:bg-red-500 text-white">Supprimer</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>
