<% title = "Confirmation — La Hora" %>
<%
  const kind = (typeof type !== 'undefined' && type === 'contact') ? 'contact' : 'reservation';
  const resv = (typeof reservation !== 'undefined' && reservation) ? reservation : null;
  const hasError = (typeof error !== 'undefined' && error);
%>

<main class="pt-24 pb-16 px-6 md:px-20">
  <div class="max-w-xl mx-auto text-center bg-gray-900 bg-opacity-80 p-8 rounded-lg shadow-lg">
    <% if (hasError) { %>
      <p class="text-red-500 mb-4"><%= error %></p>
    <% } %>

    <h1 class="text-3xl font-bold mb-6 <%= kind==='contact' ? 'text-blue-400' : 'text-green-500' %>">
      <%= kind === 'contact' ? 'Message envoyé !' : 'Réservation confirmée !' %>
    </h1>

    <p class="text-gray-300 mb-6">
      <%= kind === 'contact'
          ? "Merci pour votre message. Nous revenons vers vous dès que possible."
          : "Merci pour votre réservation. Nous avons bien reçu votre demande." %>
    </p>

    <% if (resv) { %>
      <div class="text-left bg-gray-800 bg-opacity-60 rounded-lg p-4 mb-6">
        <p class="text-gray-200"><strong>Nom :</strong> <%= resv.firstname || '' %> <%= resv.lastname || '' %></p>
        <p class="text-gray-200"><strong>Date :</strong> <%= resv.date || '' %></p>
        <p class="text-gray-200"><strong>Heure :</strong> <%= resv.time || '' %></p>
        <p class="text-gray-200"><strong>Personnes :</strong> <%= resv.people || '' %></p>
        <% if (resv.phone) { %><p class="text-gray-200"><strong>Téléphone :</strong> <%= resv.phone %></p><% } %>
        <% if (resv.email) { %><p class="text-gray-200"><strong>Email :</strong> <%= resv.email %></p><% } %>
        <% if (resv.message) { %><p class="text-gray-200"><strong>Message :</strong> <%= resv.message %></p><% } %>
      </div>
    <% } else if (kind !== 'contact') { %>
      <p class="text-sm text-gray-500 mb-6">Aucune réservation à afficher.</p>
    <% } %>

    <a href="/" class="inline-block bg-red-600 hover:bg-red-700 text-white px-6 py-2 rounded-full transition duration-200">
      Retour à l'accueil
    </a>
  </div>
</main>

<script>
  // Animation fade-in
  document.addEventListener('DOMContentLoaded', () => {
    const block = document.querySelector('.fade-in');
    if (block) {
      requestAnimationFrame(() => block.classList.add('opacity-100', 'translate-y-0'));
    }
  });
</script>
