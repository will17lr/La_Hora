<!-- views/pages/confirmation.ejs -->
<% title = "Confirmation — La Hora" %>
<%
  const kind = (typeof type === 'string' && type === 'contact') ? 'contact' : 'reservation';
  const resv = (typeof reservation === 'object' && reservation) ? reservation : null;
  const hasError = Boolean(typeof error !== 'undefined' && error);

  const H1 = (kind === 'contact') ? 'Message envoyé' : 'Réservation confirmée';
  const LEAD = (kind === 'contact')
    ? "Merci ! Nous revenons vers vous au plus vite."
    : "Merci ! Votre demande a bien été prise en compte.";
%>

<main class="pt-24 pb-16 px-6 md:px-20 bg-[var(--noir)]">
  <section class="max-w-xl mx-auto card fade-in text-center" aria-labelledby="confirm-title">
    <% if (hasError) { %>
      <div class="mb-6 rounded-lg border border-red-500/40 bg-red-500/10 text-or px-4 py-3">
        <p class="font-semibold">Erreur</p>
        <p class="text-sm"><%= error %></p>
      </div>
    <% } %>

    <h1 id="confirm-title" class="section-title mb-4"><%= H1 %> ✅</h1>
    <p class="text-or mb-8"><%= LEAD %></p>

    <% if (kind === 'reservation' && resv) { %>
      <div class="text-left bg-black/30 rounded-lg p-4 mb-8">
        <p class="text-or"><strong>Nom :</strong> <%= (resv.firstname || '') + ' ' + (resv.lastname || '') %></p>
        <p class="text-or"><strong>Date :</strong> <%= resv.date || '—' %></p>
        <p class="text-or"><strong>Heure :</strong> <%= resv.time || '—' %></p>
        <p class="text-or"><strong>Personnes :</strong> <%= resv.people || '—' %></p>
        <% if (resv.phone) { %><p class="text-or"><strong>Téléphone :</strong> <%= resv.phone %></p><% } %>
        <% if (resv.email) { %><p class="text-or"><strong>Email :</strong> <%= resv.email %></p><% } %>
        <% if (resv.message) { %><p class="text-or"><strong>Message :</strong> <%= resv.message %></p><% } %>
      </div>
    <% } %>

    <div class="flex justify-center">
      <a href="/" class="btn-primary rounded-full">Retour à l’accueil</a>
    </div>
  </section>
</main>
