<% title = "Contact – La Hora" %>
<%
  // ✅ Toujours défini, même si le contrôleur n’envoie pas 'form'
  const F = (typeof form === 'object' && form) ? form : {};
%>

<main class="pt-24 pb-16 px-6 md:px-20">
  <div class="max-w-3xl mx-auto bg-gray-900 bg-opacity-90 p-8 rounded-2xl shadow-lg">
    <h1 class="text-4xl font-bold text-center text-red-500 mb-6">Contact</h1>

    <!-- Bloc erreur serveur -->
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="mb-6 rounded-lg border border-red-500/40 bg-red-500/10 text-red-200 px-4 py-3">
        <p class="font-semibold">Erreur</p>
        <p class="text-sm"><%= error %></p>
      </div>
    <% } %>

    <form action="/contact" method="POST" class="space-y-6">
      <!-- 🕵️ Honeypot anti-spam (caché) -->
      <div class="hidden">
        <label for="website">Laissez ce champ vide</label>
        <input id="website" name="website" type="text" autocomplete="off" tabindex="-1" />
      </div>

      <!-- 👤 Nom & Téléphone -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label for="name" class="block mb-1 text-sm font-medium text-gray-100">Nom</label>
          <input
            id="name" name="name" type="text"
            value="<%= F.name || '' %>"
            class="w-full bg-white text-gray-900 placeholder-gray-500 border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-red-500/50 focus:border-red-500"
          />
        </div>
        <div>
          <label for="phone" class="block mb-1 text-sm font-medium text-gray-100">Téléphone</label>
          <input
            id="phone" name="phone" type="tel" autocomplete="tel"
            value="<%= F.phone || '' %>"
            class="w-full bg-white text-gray-900 placeholder-gray-500 border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-red-500/50 focus:border-red-500"
          />
        </div>
      </div>

      <!-- 📧 Email -->
      <div>
        <label for="email" class="block mb-1 text-sm font-medium text-gray-100">Email *</label>
        <input
          id="email" name="email" type="email" required autocomplete="email"
          value="<%= F.email || '' %>"
          class="w-full bg-white text-gray-900 placeholder-gray-500 border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-red-500/50 focus:border-red-500"
        />
      </div>

      <!-- 📝 Sujet -->
      <div>
        <label for="subject" class="block mb-1 text-sm font-medium text-gray-100">Sujet</label>
        <input
          id="subject" name="subject" type="text"
          value="<%= F.subject || '' %>"
          class="w-full bg-white text-gray-900 placeholder-gray-500 border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-red-500/50 focus:border-red-500"
        />
      </div>

      <!-- ✉️ Message -->
      <div>
        <label for="message" class="block mb-1 text-sm font-medium text-gray-100">Message *</label>
        <textarea
          id="message" name="message" rows="5" required
          class="w-full bg-white text-gray-900 placeholder-gray-500 border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-red-500/50 focus:border-red-500"
        ><%= F.message || '' %></textarea>
      </div>

      <!-- 🔘 Submit -->
      <div class="text-center pt-2">
        <button type="submit"
          class="bg-red-600 hover:bg-red-700 px-8 py-2 rounded-full text-white font-medium shadow transition">
          Envoyer
        </button>
      </div>
    </form>
  </div>
</main>
