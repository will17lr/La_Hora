<!-- views/pages/reservation.ejs -->
<% title = "Réservation – La Hora" %>
<%
  const F = (typeof form === 'object' && form) ? form : {};
%>

<main class="pt-24 pb-16 px-6 md:px-20 bg-black bg-opacity-90">
  <div class="max-w-3xl mx-auto card fade-in">
    <h1 class="section-title">Réservez une table</h1>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="mb-6 rounded-lg border border-red-500/40 bg-red-500/10 text-or px-4 py-3">
        <p class="font-semibold">Erreur</p>
        <p class="text-sm"><%= error %></p>
      </div>
    <% } %>

    <form action="/reservation" method="POST" class="space-y-6">
      <!-- 👤 Nom & Prénom -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label for="lastname" class="block mb-1 text-sm text-or">Nom</label>
          <input id="lastname" name="lastname" required value="<%= F.lastname || '' %>" class="input" />
        </div>
        <div>
          <label for="firstname" class="block mb-1 text-sm text-or">Prénom</label>
          <input id="firstname" name="firstname" required value="<%= F.firstname || '' %>" class="input" />
        </div>
      </div>

      <!-- 📞 Téléphone & Email -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label for="phone" class="block mb-1 text-sm text-or">Téléphone</label>
          <input id="phone" name="phone" type="tel" autocomplete="tel" required value="<%= F.phone || '' %>" class="input" />
        </div>
        <div>
          <label for="email" class="block mb-1 text-sm text-or">Email</label>
          <input id="email" name="email" type="email" autocomplete="email" required value="<%= F.email || '' %>" class="input" />
        </div>
      </div>

      <!-- 📅 Date & Heure -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label for="date" class="block mb-1 text-sm text-or">Date</label>
          <input id="date" name="date" type="date" required value="<%= F.date || '' %>" class="input" />
        </div>
        <div>
          <label for="time" class="block mb-1 text-sm text-or">Heure</label>
          <input
            id="time" name="time" type="time" step="900" list="timeOptions"
            value="<%= F.time || '' %>" disabled aria-disabled="true"
            class="input disabled:opacity-60 disabled:cursor-not-allowed"
          />
          <datalist id="timeOptions"></datalist>
          <p id="hoursHint" class="hint">
            <%= F.date ? '' : "Choisissez une date pour afficher les horaires disponibles." %>
          </p>
          <p id="timeError" class="mt-1 text-sm text-or hidden"></p>
        </div>
      </div>

      <!-- 👥 Nombre de personnes -->
      <div>
        <label for="people" class="block mb-1 text-sm text-or">Nombre de personnes</label>
        <input id="people" name="people" type="number" min="1" required
               value="<%= (typeof F.people !== 'undefined' && F.people !== null) ? F.people : '' %>"
               class="input" />
      </div>

      <!-- ✉️ Message -->
      <div>
        <label for="message" class="block mb-1 text-sm text-or">Message (facultatif)</label>
        <textarea id="message" name="message" rows="4" class="input resize-none"><%= F.message || '' %></textarea>
      </div>

      <!-- 🔘 Submit -->
      <div class="text-center pt-4">
        <button type="submit" class="btn-primary px-8 rounded-full hover:scale-105 transition">Réserver</button>
      </div>
    </form>
  </div>
</main>

<script>
  // === Horaires d'ouverture (0=Dim ... 6=Sam) — adapte ici ===
  const OPENING_HOURS = {
    0: [], // Dimanche fermé
    1: [['10:00','14:30'], ['18:00','23:30']],
    2: [['10:00','14:30'], ['18:00','23:30']],
    3: [['10:00','14:30'], ['18:00','23:30']],
    4: [['10:00','14:30'], ['18:00','23:30']],
    5: [['10:00','14:30'], ['18:00','00:30']],
    6: [['10:00','14:30'], ['18:00','00:30']],
  };
  const STEP_MINUTES = 15;

  const dateEl = document.getElementById('date');
  const timeEl = document.getElementById('time');
  const listEl = document.getElementById('timeOptions');
  const hoursHint = document.getElementById('hoursHint');
  const timeError = document.getElementById('timeError');
  const formEl = document.querySelector('form[action="/reservation"]');

  const pad = (n) => String(n).padStart(2,'0');
  const toMinutes = (hhmm) => { const [h,m]=hhmm.split(':').map(Number); return h*60+m; };
  const minutesToHHMM = (mins) => `${pad(Math.floor(mins/60))}:${pad(mins%60)}`;
  const roundUpToStep = (mins, step) => Math.ceil(mins/step)*step;

  function genSlots(start, end){
    let s=toMinutes(start), e=toMinutes(end);
    if (e < s) e += 24*60; // dépasse minuit
    const out=[];
    for(let t=s; t<=e; t+=STEP_MINUTES) out.push(minutesToHHMM(t%(24*60)));
    return out;
  }
  const slotsForDay = (day) => (OPENING_HOURS[day]||[]).flatMap(([a,b])=>genSlots(a,b));

  function setDateMinToday(){
    const todayIso = new Date().toISOString().slice(0,10);
    dateEl.setAttribute('min', todayIso);
  }

  function disableTime(msg){
    timeEl.value='';
    timeEl.disabled=true;
    timeEl.setAttribute('aria-disabled','true');
    listEl.innerHTML='';
    hoursHint.textContent = msg || 'Choisissez une date pour afficher les horaires disponibles.';
  }
  function enableTime(msg){
    timeEl.disabled=false;
    timeEl.removeAttribute('aria-disabled');
    hoursHint.textContent = msg || '';
  }

  function updateTimeOptionsForDate(){
    timeError.classList.add('hidden');
    listEl.innerHTML='';

    const value = dateEl.value;
    if(!value){ disableTime(); return; }

    const d = new Date(`${value}T00:00:00`);
    const day = d.getDay();
    let slots = slotsForDay(day);

    const todayIso = new Date().toISOString().slice(0,10);
    if(value === todayIso){
      const now = new Date();
      const nowMin = now.getHours()*60 + now.getMinutes();
      const minAllowed = roundUpToStep(nowMin, STEP_MINUTES);
      slots = slots.filter(hhmm => toMinutes(hhmm) >= minAllowed);
    }

    if(slots.length === 0){
      const isToday = value === todayIso;
      disableTime(isToday ? "Plus de créneaux disponibles aujourd’hui." : "Fermé ce jour.");
      return;
    }

    const frag = document.createDocumentFragment();
    slots.forEach(hhmm => { const opt=document.createElement('option'); opt.value=hhmm; frag.appendChild(opt); });
    listEl.appendChild(frag);

    const ranges = (OPENING_HOURS[day]||[]).map(([a,b])=>`${a}–${b}`).join(' et ');
    enableTime(`Horaires disponibles : ${ranges} (créneaux de ${STEP_MINUTES} min)`);

    if(timeEl.value && !slots.includes(timeEl.value)) timeEl.value='';
  }

  function validateTimeAgainstOpenHours(e){
    timeError.classList.add('hidden');

    const dateVal = dateEl.value;
    const timeVal = timeEl.value;
    if(!dateVal){ e.preventDefault(); timeError.textContent="Sélectionnez d'abord une date."; timeError.classList.remove('hidden'); dateEl.focus(); return; }
    if(timeEl.disabled || !timeVal){ e.preventDefault(); timeError.textContent="Sélectionnez une heure d'ouverture pour ce jour."; timeError.classList.remove('hidden'); timeEl.focus(); return; }

    const day = new Date(`${dateVal}T00:00:00`).getDay();
    let slots = slotsForDay(day);

    const todayIso = new Date().toISOString().slice(0,10);
    if(dateVal === todayIso){
      const now = new Date();
      const nowMin = now.getHours()*60 + now.getMinutes();
      const minAllowed = roundUpToStep(nowMin, STEP_MINUTES);
      slots = slots.filter(hhmm => toMinutes(hhmm) >= minAllowed);
    }

    if(!slots.includes(timeVal)){
      e.preventDefault();
      timeError.textContent="L’heure choisie n’est pas dans les horaires d’ouverture.";
      timeError.classList.remove('hidden');
      timeEl.focus();
    }
  }

  setDateMinToday();
  if(dateEl.value) updateTimeOptionsForDate(); else disableTime();

  dateEl.addEventListener('change', updateTimeOptionsForDate);
  formEl.addEventListener('submit', validateTimeAgainstOpenHours);
</script>
